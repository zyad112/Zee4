rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function isValidStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Counter Update Validators
    // ===============================================================
    function isValidLikeUpdate(tweetId) {
      let trackingDocId = request.auth.uid + '_' + tweetId;
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount']) &&
             math.abs(request.resource.data.likesCount - resource.data.likesCount) == 1 &&
             (
               (request.resource.data.likesCount > resource.data.likesCount &&
                !exists(/databases/$(database)/documents/likes/$(trackingDocId)) &&
                getAfter(/databases/$(database)/documents/likes/$(trackingDocId)) != null) ||
               (request.resource.data.likesCount < resource.data.likesCount &&
                exists(/databases/$(database)/documents/likes/$(trackingDocId)) &&
                getAfter(/databases/$(database)/documents/likes/$(trackingDocId)) == null)
             );
    }

    function isValidRetweetUpdate(tweetId) {
      let trackingDocId = request.auth.uid + '_' + tweetId;
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['retweetsCount']) &&
             math.abs(request.resource.data.retweetsCount - resource.data.retweetsCount) == 1 &&
             (
               (request.resource.data.retweetsCount > resource.data.retweetsCount &&
                !exists(/databases/$(database)/documents/retweets/$(trackingDocId)) &&
                getAfter(/databases/$(database)/documents/retweets/$(trackingDocId)) != null) ||
               (request.resource.data.retweetsCount < resource.data.retweetsCount &&
                exists(/databases/$(database)/documents/retweets/$(trackingDocId)) &&
                getAfter(/databases/$(database)/documents/retweets/$(trackingDocId)) == null)
             );
    }

    function isValidReplyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['repliesCount']) &&
             math.abs(request.resource.data.repliesCount - resource.data.repliesCount) == 1;
    }

    function isValidFollowUpdate(userId) {
      let trackingDocId = request.auth.uid + '_' + userId;
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount']) &&
             math.abs(request.resource.data.followersCount - resource.data.followersCount) == 1 &&
             (
               (request.resource.data.followersCount > resource.data.followersCount &&
                !exists(/databases/$(database)/documents/follows/$(trackingDocId)) &&
                getAfter(/databases/$(database)/documents/follows/$(trackingDocId)) != null) ||
               (request.resource.data.followersCount < resource.data.followersCount &&
                exists(/databases/$(database)/documents/follows/$(trackingDocId)) &&
                getAfter(/databases/$(database)/documents/follows/$(trackingDocId)) == null)
             );
    }

    function isValidFollowingUpdate(userId) {
      let trackingDocId = userId + '_' + request.resource.data.diff(resource.data).affectedKeys()[0]; // Simplified for now, just checking if followingCount changes
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followingCount']) &&
             math.abs(request.resource.data.followingCount - resource.data.followingCount) == 1;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'handle', 'photoURL', 'coverURL', 'bio', 'createdAt', 'followersCount', 'followingCount', 'phoneNumber', 'socialLinks', 'isSetupComplete', 'isVerified', 'verificationExpiry', 'hasUsedFreeVerification', 'privacySettings']) &&
             data.uid == request.auth.uid &&
             isValidStringLength('displayName', 1, 50) &&
             isValidStringLength('handle', 3, 20) &&
             isValidOptionalString('photoURL', 0, 2000) &&
             isValidOptionalString('coverURL', 0, 2000) &&
             isValidOptionalString('bio', 0, 1000) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
             (!('socialLinks' in data) || data.socialLinks is map) &&
             (!('isSetupComplete' in data) || data.isSetupComplete is bool) &&
             (!('isVerified' in data) || data.isVerified is bool) &&
             (!('verificationExpiry' in data) || data.verificationExpiry is number) &&
             (!('hasUsedFreeVerification' in data) || data.hasUsedFreeVerification is bool) &&
             (!('privacySettings' in data) || data.privacySettings is map) &&
             data.createdAt is number &&
             data.followersCount is number &&
             data.followingCount is number;
    }

    function isValidTweet() {
      return hasOnlyAllowedFields(['authorId', 'authorName', 'authorHandle', 'authorPhoto', 'text', 'createdAt', 'likesCount', 'retweetsCount', 'repliesCount', 'imageUrl']) &&
             request.resource.data.authorId == request.auth.uid &&
             isValidOptionalString('text', 0, 10000) &&
             isValidOptionalString('imageUrl', 0, 1048576) &&
             request.resource.data.createdAt is number &&
             request.resource.data.likesCount is number &&
             request.resource.data.retweetsCount is number &&
             request.resource.data.repliesCount is number;
    }

    // ===============================================================
    // Collections
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser() &&
                    request.resource.data.followersCount == 0 &&
                    request.resource.data.followingCount == 0;
      allow update: if isAuthenticated() && (
                      (isOwner(userId) && isValidUser() && areImmutableFieldsUnchanged(['uid', 'createdAt', 'followersCount', 'followingCount'])) ||
                      isValidFollowUpdate(userId) ||
                      (isOwner(userId) && isValidFollowingUpdate(userId))
                    );
    }

    match /tweets/{tweetId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTweet() &&
                    request.resource.data.likesCount == 0 &&
                    request.resource.data.retweetsCount == 0 &&
                    request.resource.data.repliesCount == 0;
      allow update: if isAuthenticated() && (
                      (request.resource.data.authorId == resource.data.authorId &&
                       resource.data.authorId == request.auth.uid &&
                       areImmutableFieldsUnchanged(['authorId', 'createdAt', 'likesCount', 'retweetsCount', 'repliesCount']) &&
                       isValidOptionalString('text', 0, 10000) &&
                       isValidOptionalString('imageUrl', 0, 1048576)) ||
                      isValidLikeUpdate(tweetId) ||
                      isValidRetweetUpdate(tweetId) ||
                      isValidReplyUpdate()
                    );
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    match /likes/{likeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    likeId == request.auth.uid + '_' + request.resource.data.tweetId &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.keys().hasOnly(['userId', 'tweetId', 'createdAt']) &&
                    request.resource.data.createdAt is number;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /retweets/{retweetId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    retweetId == request.auth.uid + '_' + request.resource.data.tweetId &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.keys().hasOnly(['userId', 'tweetId', 'createdAt']) &&
                    request.resource.data.createdAt is number;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    followId == request.auth.uid + '_' + request.resource.data.followingId &&
                    request.resource.data.followerId == request.auth.uid &&
                    request.resource.data.keys().hasOnly(['followerId', 'followingId', 'createdAt']) &&
                    request.resource.data.createdAt is number;
      allow delete: if isAuthenticated() && resource.data.followerId == request.auth.uid;
    }

    match /replies/{replyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    request.resource.data.authorId == request.auth.uid &&
                    request.resource.data.keys().hasOnly(['tweetId', 'authorId', 'authorName', 'authorHandle', 'authorPhoto', 'text', 'createdAt', 'imageUrl']) &&
                    isValidOptionalString('text', 0, 10000) &&
                    isValidOptionalString('imageUrl', 0, 1048576) &&
                    request.resource.data.createdAt is number;
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
                    request.resource.data.actorId == request.auth.uid &&
                    request.resource.data.keys().hasOnly(['userId', 'actorId', 'actorName', 'actorPhoto', 'type', 'tweetId', 'text', 'createdAt', 'read']) &&
                    request.resource.data.type in ['like', 'retweet', 'reply', 'follow'] &&
                    request.resource.data.createdAt is number &&
                    request.resource.data.read == false;
      allow update: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
                    request.resource.data.read == true;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /used_codes/{codeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                    request.resource.data.keys().hasOnly(['usedBy', 'usedAt']) &&
                    request.resource.data.usedBy == request.auth.uid &&
                    request.resource.data.usedAt is number;
    }
    // ===============================================================
    // Chats Collection
    // ===============================================================
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
                    request.auth.uid in request.resource.data.participants &&
                    request.resource.data.participants is list &&
                    request.resource.data.participants.size() == 2;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
    }

    // ===============================================================
    // Messages Collection
    // ===============================================================
    match /messages/{messageId} {
      allow read: if isAuthenticated() &&
                  request.auth.uid in get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.participants;
      allow create: if isAuthenticated() &&
                    request.resource.data.senderId == request.auth.uid &&
                    request.auth.uid in get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.participants;
      allow update: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }

    // ===============================================================
    // Groups Collection
    // ===============================================================
    match /groups/{groupId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.members;
      allow create: if isAuthenticated() &&
                    request.resource.data.ownerId == request.auth.uid &&
                    request.auth.uid in request.resource.data.members;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.members;
    }

    // ===============================================================
    // Group Messages Collection
    // ===============================================================
    match /group_messages/{messageId} {
      allow read: if isAuthenticated() &&
                  request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.members;
      allow create: if isAuthenticated() &&
                    request.resource.data.senderId == request.auth.uid &&
                    request.auth.uid in get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.members;
      allow update: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }

  }
}
